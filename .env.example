# LinkedIn session cookie — get it from your browser:
# 1. Go to linkedin.com (logged in as Hamza's account or any account)
# 2. Open DevTools → Application → Cookies → https://www.linkedin.com
# 3. Copy the value of the cookie named "li_at"
# 4. Paste it below — never commit this file
LINKEDIN_LI_AT=

# France Travail API (optional — free, register at francetravail.io)
# FRANCE_TRAVAIL_CLIENT_ID=
# FRANCE_TRAVAIL_CLIENT_SECRET=
